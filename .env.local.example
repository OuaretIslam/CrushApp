# Supabase - get from supabase.com > your project > settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini - get from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq fallback - get from console.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter emergency fallback - get from openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=qwen/qwen3-8b:free

# Brevo - get from brevo.com
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=whatever@youremail.com

# App URL - change to your Vercel URL after deploy
NEXT_PUBLIC_APP_URL=http://localhost:3000
